# A 股 TradingAgents 环境变量示例
#
# 使用方式：
# 1. 不要把真实 API Key 写进代码。
# 2. 可以把本文件复制成 .env 自己留存。
# 3. Windows 系统环境变量里也要配置对应 API Key。

# 默认不设置 TRADINGAGENTS_CN_LLM_PROVIDER 时，程序会使用：
# DeepSeek -> Gemini
# 也就是先调用 DeepSeek，DeepSeek 失败后自动切到 Gemini。
#
# 如果你想强制只用某一个模型服务商，再设置：
# TRADINGAGENTS_CN_LLM_PROVIDER=deepseek
# TRADINGAGENTS_CN_LLM_PROVIDER=gemini
TRADINGAGENTS_CN_LLM_FALLBACK_PROVIDERS=deepseek,gemini
DEEPSEEK_API_KEY=sk-替换成你自己的key
DEEPSEEK_MODEL=deepseek-chat

# 可选：OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# 可选：Kimi / Moonshot
KIMI_API_KEY=
KIMI_MODEL=moonshot-v1-8k

# 可选：Gemini
# GEMINI_API_KEY 和 GOOGLE_API_KEY 二选一即可。
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions

# 可选：SQLite checkpoint 数据库路径
TRADINGAGENTS_CN_CHECKPOINT_DB=outputs/checkpoints/tradingagents_cn_checkpoints.sqlite

# 可选：原材料文本缓存目录
TRADINGAGENTS_CN_CACHE_DIR=outputs/cache
